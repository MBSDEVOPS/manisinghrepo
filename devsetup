#!/bin/bash

# ===============================
# DevSetup Self Installer
# ===============================

INSTALL_PATH="/usr/local/bin/devsetup"

if [[ "$0" == "bash" || "$0" == "sh" ]]; then
    echo "[DevSetup] Installing globally..."

    TMP_FILE="/tmp/devsetup"

    curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetup -o "$TMP_FILE"

    sudo mv "$TMP_FILE" "$INSTALL_PATH"
    sudo chmod +x "$INSTALL_PATH"

    echo ""
    echo "вң… DevSetup installed successfully!"
    echo "Run: devsetup --help"
    echo ""
    exit 0
fi

# ===============================
# CONFIG
# ===============================

VERSION="1.0.0"
LOG_DIR="$HOME/.devsetup/logs"
LOG_FILE="$LOG_DIR/devsetup.log"
CONFIG_DIR="$HOME/.devsetup"

mkdir -p "$LOG_DIR"
mkdir -p "$CONFIG_DIR"

# ===============================
# COLORS
# ===============================

GREEN="\e[32m"
YELLOW="\e[33m"
RED="\e[31m"
BLUE="\e[34m"
CYAN="\e[36m"
RESET="\e[0m"

