# =====================================
# SPINNER
# =====================================
spinner(){
    local pid=$!
    local delay=0.1
    local spin='|/-\'
    while ps -p $pid >/dev/null 2>&1; do
        printf " [%c]  " "$spin"
        spin=${spin#?}${spin%"${spin#?}"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# =====================================
# SELF INSTALL (curl | bash)
# =====================================
if [[ "$0" == "bash" ]] || [[ "$0" == "-bash" ]]; then
    echo "Installing DevSetup globally..."
    curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetup -o /tmp/devsetup
    sudo mv /tmp/devsetup /usr/local/bin/devsetup
    sudo chmod +x /usr/local/bin/devsetup
    echo "Installed! Run: devsetup --help"
    exit 0
fi

# =====================================
# OS DETECTION
# =====================================
if command -v apt-get &>/dev/null; then
    PKG_INSTALL="sudo apt-get install -y"
    PKG_UPDATE="sudo apt-get update -y"
elif command -v dnf &>/dev/null; then
    PKG_INSTALL="sudo dnf install -y"
    PKG_UPDATE="sudo dnf update -y"
else
    error "Unsupported OS"
    exit 1
fi

already_installed(){ command -v "$1" &>/dev/null; }

# =====================================
# DIRECTORY PROVISIONING
# =====================================
setup_directories(){
    info "Creating DevOps workspace..."
    mkdir -p ~/projects/dev ~/projects/test ~/projects/scripts
    success "Directories ready"
}

# =====================================
# DEPENDENCIES
# =====================================
install_dep(){
    if ! already_installed "$1"; then
        info "Installing dependency: $1"
        ($PKG_INSTALL "$2" >>"$LOG_FILE" 2>&1) & spinner
        success "$1 installed"
    fi
}

check_dependencies(){
    install_dep curl curl
    install_dep unzip unzip
    install_dep python3 python3
}

# =====================================
# TOOL INSTALLERS (IDEMPOTENT)
# =====================================
install_docker(){
already_installed docker && success "Docker already installed" || {
info "Installing Docker..."
($PKG_INSTALL docker >>"$LOG_FILE" 2>&1) & spinner
sudo systemctl enable docker >/dev/null 2>&1
sudo systemctl start docker
success "Docker installed"
}
}

install_aws(){
already_installed aws && success "AWS CLI already installed" || {
info "Installing AWS CLI..."
($PKG_INSTALL awscli >>"$LOG_FILE" 2>&1) & spinner
success "AWS CLI installed"
}
}

install_terraform(){
already_installed terraform && success "Terraform already installed" || {
info "Installing Terraform..."
sudo dnf install -y yum-utils >/dev/null 2>&1
sudo yum-config-manager --add-repo https://rpm.releases.hashicorp.com/AmazonLinux/hashicorp.repo >/dev/null 2>&1
($PKG_INSTALL terraform >>"$LOG_FILE" 2>&1) & spinner
success "Terraform installed"
}
}

install_kubectl(){
already_installed kubectl && success "kubectl already installed" || {
info "Installing kubectl..."
(curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" >>"$LOG_FILE" 2>&1) & spinner
chmod +x kubectl
sudo mv kubectl /usr/local/bin/
success "kubectl installed"
}
}

install_ansible(){
already_installed ansible && success "Ansible already installed" || {
info "Installing Ansible..."
($PKG_INSTALL ansible >>"$LOG_FILE" 2>&1) & spinner
success "Ansible installed"
}
}

install_node(){
already_installed node && success "Node.js already installed" || {
info "Installing Node.js..."
($PKG_INSTALL nodejs >>"$LOG_FILE" 2>&1) & spinner
success "Node.js installed"
}
}

# =====================================
# INTERACTIVE INSTALL
# =====================================
interactive_install(){
read -p "Install Docker? (y/n): " x; [[ $x == y ]] && install_docker
read -p "Install AWS CLI? (y/n): " x; [[ $x == y ]] && install_aws
read -p "Install Terraform? (y/n): " x; [[ $x == y ]] && install_terraform
read -p "Install kubectl? (y/n): " x; [[ $x == y ]] && install_kubectl
read -p "Install Ansible? (y/n): " x; [[ $x == y ]] && install_ansible
read -p "Install Node.js? (y/n): " x; [[ $x == y ]] && install_node
}

# =====================================
# VALIDATE
# =====================================
validate_tools(){
info "Validating installed tools..."
docker --version 2>/dev/null || warning "Docker NOT installed"
aws --version 2>/dev/null || warning "AWS CLI NOT installed"
terraform version 2>/dev/null || warning "Terraform NOT installed"
kubectl version --client 2>/dev/null || warning "kubectl NOT installed"
node -v 2>/dev/null || warning "Node.js NOT installed"
ansible --version 2>/dev/null || warning "Ansible NOT installed"
success "Validation completed"
}

# =====================================
# DOCTOR
# =====================================
doctor_check(){
info "Running system diagnostics..."

[[ -f /etc/os-release ]] && success "OS detected"

ping -c 1 google.com &>/dev/null \
&& success "Internet OK" \
|| warning "No internet"

success "Disk: $(df -h / | awk 'NR==2 {print $5}')"
success "Memory: $(free -h | awk '/Mem:/ {print $3 "/" $2}')"

command -v docker &>/dev/null && success "Docker installed" || warning "Docker missing"
command -v kubectl &>/dev/null && success "kubectl installed" || warning "kubectl missing"
command -v terraform &>/dev/null && success "Terraform installed" || warning "Terraform missing"
command -v aws &>/dev/null && success "AWS CLI installed" || warning "AWS CLI missing"

success "Doctor check completed"
}

# =====================================
# CLEANUP
# =====================================
cleanup_env(){
info "Cleaning DevSetup environment..."
rm -rf "$BASE_DIR" ~/projects
success "Cleanup completed"
}

# =====================================
# HELP
# =====================================
show_help(){
cat <<EOF

DevSetup CLI Tool $VERSION

Commands:
  install
  validate
  doctor
  cleanup

Options:
  --interactive
  --help
  --version

EOF
}

# =====================================
# INSTALL FLOW
# =====================================
install_command(){

info "Starting DevOps setup..."

check_dependencies

info "Updating OS packages..."
($PKG_UPDATE >>"$LOG_FILE" 2>&1) & spinner
success "OS updated"

setup_directories

$INTERACTIVE && interactive_install

success "Installation Completed!"
}

# =====================================
# ROUTER
# =====================================
COMMAND=$1
shift

for arg in "$@"; do
case $arg in
--interactive) INTERACTIVE=true ;;
--help) show_help; exit ;;
--version) echo "DevSetup CLI Tool $VERSION"; exit ;;
esac
done

show_banner

case "$COMMAND" in
install) install_command ;;
validate) validate_tools ;;
doctor) doctor_check ;;
cleanup) cleanup_env ;;
""|--help) show_help ;;
*) error "Unknown command. Use devsetup --help" ;;
esac
        
