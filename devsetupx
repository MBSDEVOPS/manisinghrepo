########################################
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[1;35m'
NC='\033[0m'

success(){ echo -e "${GREEN}‚úĒ $1${NC}"; }
error(){ echo -e "${RED}‚úĖ $1${NC}"; }
info(){ echo -e "${CYAN}‚ěú $1${NC}"; }
warn(){ echo -e "${YELLOW}‚ö† $1${NC}"; }

########################################
# SPINNER (npm-style feel)
########################################
spinner(){
    local pid=$!
    local spin='-\|/'
    local i=0
    while kill -0 $pid 2>/dev/null; do
        i=$(( (i+1) %4 ))
        printf "\r${CYAN}[${spin:$i:1}] Working...${NC}"
        sleep .1
    done
    printf "\r"
}

########################################
# DETECTION
########################################
detect_pkg(){
    if command -v apt >/dev/null; then PKG="apt"
    elif command -v dnf >/dev/null; then PKG="dnf"
    elif command -v yum >/dev/null; then PKG="yum"
    elif command -v brew >/dev/null; then PKG="brew"
    else PKG="unknown"
    fi
}

already(){ command -v "$1" >/dev/null 2>&1; }

install_pkg(){
    local PK=$1

    already "$PK" && { success "$PK already installed"; return; }

    info "Installing $PK..."

    (
        case "$PKG" in
            apt) sudo apt-get update -y && sudo apt-get install -y "$PK" ;;
            dnf|yum) sudo $PKG install -y "$PK" ;;
            brew) brew install "$PK" ;;
            *) error "Unsupported package manager"; exit 1 ;;
        esac
    ) & spinner

    success "$PK installed"
}

