########################################
# DETECTION ENGINE
########################################
detect_os(){
  case "$(uname -s)" in
    Linux*) OS="Linux" ;;
    Darwin*) OS="macOS" ;;
    *) OS="Unknown" ;;
  esac
}

detect_arch(){
  case "$(uname -m)" in
    x86_64) ARCH="amd64" ;;
    aarch64|arm64) ARCH="arm64" ;;
    *) ARCH="unknown" ;;
  esac
}

detect_pkg(){
  if command -v apt >/dev/null; then PKG="apt"
  elif command -v dnf >/dev/null; then PKG="dnf"
  elif command -v yum >/dev/null; then PKG="yum"
  elif command -v brew >/dev/null; then PKG="brew"
  else PKG="unknown"
  fi
}

detect_cloud(){
  CLOUD="Local"
  curl -s --connect-timeout 1 http://169.254.169.254/latest/meta-data/ >/dev/null 2>&1 && CLOUD="AWS"
  curl -s -H Metadata:true "http://169.254.169.254/metadata/instance?api-version=2021-02-01" >/dev/null 2>&1 && CLOUD="Azure"
  curl -s -H "Metadata-Flavor: Google" http://metadata.google.internal >/dev/null 2>&1 && CLOUD="GCP"
}

########################################
# TOOL DETECTION
########################################
already_installed(){
  command -v "$1" >/dev/null 2>&1
}

install_pkg(){
  PK=$1
  if already_installed "$PK"; then
    success "$PK already installed (skipped)"
    return
  fi

  info "Installing $PK..."
  case "$PKG" in
    apt) sudo apt-get update -y && sudo apt-get install -y "$PK" ;;
    dnf|yum) sudo $PKG install -y "$PK" ;;
    brew) brew install "$PK" ;;
    *) error "Unsupported package manager"; return ;;
  esac
  success "$PK installed"
}

