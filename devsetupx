########################################
# ENTERPRISE ANSIBLE SETUP
########################################
install_ansible(){
    install_pkg python3
    install_pkg python3-pip
    pip3 install --user --upgrade pip ansible-core

    mkdir -p ~/ansible/{inventory,playbooks,roles}

cat <<EOF > ~/ansible/inventory/hosts
[local]
localhost ansible_connection=local
EOF

cat <<EOF > ~/ansible/ansible.cfg
[defaults]
inventory = ./inventory/hosts
host_key_checking = False
retry_files_enabled = False
EOF

    success "Enterprise Ansible environment ready"
}

########################################
# TOOL INSTALLERS
########################################
install_docker(){ install_pkg docker.io || install_pkg docker; }
install_compose(){ install_pkg docker-compose-plugin || install_pkg docker-compose; }
install_kubectl(){ install_pkg kubectl; }
install_terraform(){ install_pkg terraform; }
install_node(){ install_pkg nodejs; install_pkg npm; }
install_aws(){ install_pkg awscli; }
install_azure(){ install_pkg azure-cli; }
install_gcp(){ install_pkg google-cloud-cli; }
install_openshift(){ install_pkg origin-clients || true; }

########################################
# PARALLEL INSTALL ENGINE
########################################
parallel_all(){
    info "Running parallel enterprise installation..."

    install_docker &
    install_compose &
    install_kubectl &
    install_terraform &
    install_node &
    install_aws &
    install_ansible &
    install_openshift &

    wait
    success "All tools installed"
}

########################################
# DOCTOR (Health Check)
########################################
doctor(){
echo ""
info "System Health Check"
for cmd in docker kubectl terraform node aws ansible; do
    if already "$cmd"; then
        success "$cmd OK"
    else
        warn "$cmd missing"
    fi
done
}

########################################
# HELP
########################################
help_cmd(){
cat <<EOF
DevSetupX Commands:

devsetupx --interactive   Interactive install
devsetupx --auto all      Install everything
devsetupx doctor          Health check
devsetupx update          Self update
devsetupx help            Show help
devsetupx --dry-run all   Simulation mode
EOF
}

########################################
# SAFE UPDATE (ROLLBACK ENABLED)
########################################
self_update(){
TMP="/tmp/devsetupx_new"
BACKUP="/usr/local/bin/devsetupx.bak"

info "Downloading latest DevSetupX..."

curl -fsSL "$REPO_RAW" -o "$TMP"

if [[ ! -s "$TMP" ]]; then
    error "Download failed"
    exit 1
fi

sudo cp /usr/local/bin/devsetupx "$BACKUP" || true

if sudo mv "$TMP" /usr/local/bin/devsetupx; then
    sudo chmod 755 /usr/local/bin/devsetupx
    success "Updated successfully"
else
    warn "Rollback triggered"
    sudo mv "$BACKUP" /usr/local/bin/devsetupx
fi
}

########################################
# VERSION AUTO CHECK
########################################
version_check(){
REMOTE=$(curl -fsSL "$REPO_RAW" | grep VERSION= | head -1 | cut -d'"' -f2 || true)
[[ "$REMOTE" != "$VERSION" && -n "$REMOTE" ]] && \
warn "New version available: $REMOTE (run: devsetupx update)"
}

########################################
# INTERACTIVE MODE
########################################
interactive(){
read -p "Install ALL tools? (y/n): " c
[[ "$c" =~ ^[Yy]$ ]] && parallel_all
}

########################################
# ENTRY
########################################
detect_pkg
banner
version_check

case "${1:-}" in
    --interactive) interactive ;;
    --auto) parallel_all ;;
    doctor) doctor ;;
    help) help_cmd ;;
    update) self_update ;;
    --dry-run) info "Dry-run mode enabled (simulation only)" ;;
    *) help_cmd ;;
esac
