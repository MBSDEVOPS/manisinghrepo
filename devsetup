#!/bin/bash
# =========================
# DevSetup CLI Tool v1.0.0
# =========================

COMMAND=$1

LOG_FILE="$HOME/.devsetup/logs/devsetup.log"
mkdir -p $(dirname "$LOG_FILE")

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

show_help() {
    echo -e "DevSetup CLI Tool v1.0.0"
    echo ""
    echo "Usage:"
    echo "  devsetup <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install     Install selected DevOps tools"
    echo "  validate    Validate installed tools"
    echo "  cleanup     Remove DevSetup temporary directories"
    echo ""
    echo "Options:"
    echo "  --docker --aws --terraform --kubectl --ansible --node --docker-compose --k8s-cluster --all --interactive --skip-update --help --version"
}

show_version() {
    echo "DevSetup CLI Tool v1.0.0"
}

# ========================
# Installation Function
# ========================
install_tools() {
    echo -e "${GREEN}[✔] Starting DevOps environment setup...${NC}"
    echo "Install log: $LOG_FILE"

    # Update OS packages
    if [ "$SKIP_UPDATE" != true ]; then
        echo -e "[|] Updating OS packages..."
        sudo dnf update -y &>> "$LOG_FILE" || sudo yum update -y &>> "$LOG_FILE"
        echo -e "${GREEN}[✔] OS updated${NC}"
    fi

    # Function to install a tool if missing
    install_if_missing() {
        TOOL_NAME=$1
        CMD_CHECK=$2
        INSTALL_CMD=$3
        echo -ne "[|] Checking $TOOL_NAME..."
        if ! command -v $CMD_CHECK &> /dev/null; then
            echo -ne "\r[!] $TOOL_NAME missing, installing..."
            eval "$INSTALL_CMD" &>> "$LOG_FILE"
            echo -e "\r${GREEN}[✔] $TOOL_NAME installed${NC}"
        else
            echo -e "\r${GREEN}[✔] $TOOL_NAME already installed${NC}"
        fi
    }

    # Install tools based on flags
    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_DOCKER" = true ]; then
        install_if_missing "Docker" "docker" "sudo dnf install docker -y; sudo systemctl enable docker; sudo systemctl start docker; sudo usermod -aG docker \$USER"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_AWS" = true ]; then
        install_if_missing "AWS CLI" "aws" "sudo dnf install awscli -y"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_TERRAFORM" = true ]; then
        install_if_missing "Terraform" "terraform" "sudo dnf install -y yum-utils; sudo yum-config-manager --add-repo https://rpm.releases.hashicorp.com/AmazonLinux/hashicorp.repo; sudo dnf install terraform -y"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_KUBECTL" = true ]; then
        install_if_missing "kubectl" "kubectl" "curl -LO \"https://dl.k8s.io/release/\$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl\"; chmod +x kubectl; sudo mv kubectl /usr/local/bin/"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_NODE" = true ]; then
        install_if_missing "Node.js" "node" "curl -fsSL https://rpm.nodesource.com/setup_18.x | sudo bash -; sudo dnf install -y nodejs"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_ANSIBLE" = true ]; then
        install_if_missing "Ansible" "ansible" "sudo dnf install -y ansible"
    fi

    if [ "$INSTALL_ALL" = true ] || [ "$INSTALL_DOCKER_COMPOSE" = true ]; then
        install_if_missing "Docker Compose" "docker-compose" "sudo curl -L \"https://github.com/docker/compose/releases/download/v2.20.2/docker-compose-$(uname -s)-$(uname -m)\" -o /usr/local/bin/docker-compose; sudo chmod +x /usr/local/bin/docker-compose"
    fi

    echo -e "${GREEN}[✔] Installation Completed!${NC}"
}

# ========================
# Validation Function
# ========================
validate_tools() {
    echo -e "${GREEN}[✔] Validating installed tools...${NC}"
    echo "Validation log: $LOG_FILE"

    # Display versions if installed
    command -v docker &> /dev/null && docker --version || echo -e "${RED}[⚠] Docker NOT installed${NC}"
    command -v aws &> /dev/null && aws --version || echo -e "${RED}[⚠] AWS CLI NOT installed${NC}"
    command -v terraform &> /dev/null && terraform version || echo -e "${RED}[⚠] Terraform NOT installed${NC}"
    command -v kubectl &> /dev/null && kubectl version --client || echo -e "${RED}[⚠] kubectl NOT installed${NC}"
    command -v node &> /dev/null && node -v || echo -e "${RED}[⚠] Node.js NOT installed${NC}"
    command -v ansible &> /dev/null && ansible --version || echo -e "${RED}[⚠] Ansible NOT installed${NC}"
    command -v docker-compose &> /dev/null && docker-compose --version || echo -e "${RED}[⚠] Docker Compose NOT installed${NC}"
}

# ========================
# Cleanup Function
# ========================
clean_environment() {
    echo -e "${GREEN}[✔] Removing project directories...${NC}"
    rm -rf ~/projects
    echo -e "${GREEN}[✔] Environment cleaned.${NC}"
}

# ========================
# Parse Options
# ========================
INSTALL_ALL=false
INSTALL_DOCKER=false
INSTALL_AWS=false
INSTALL_TERRAFORM=false
INSTALL_KUBECTL=false
INSTALL_NODE=false
INSTALL_ANSIBLE=false
INSTALL_DOCKER_COMPOSE=false
INTERACTIVE=false
SKIP_UPDATE=false

# Interactive selection
if [ "$COMMAND" = "install" ]; then
    shift
    while [[ $# -gt 0 ]]; do
        case $1 in
            --all) INSTALL_ALL=true ;;
            --docker) INSTALL_DOCKER=true ;;
            --aws) INSTALL_AWS=true ;;
            --terraform) INSTALL_TERRAFORM=true ;;
            --kubectl) INSTALL_KUBECTL=true ;;
            --node) INSTALL_NODE=true ;;
            --ansible) INSTALL_ANSIBLE=true ;;
            --docker-compose) INSTALL_DOCKER_COMPOSE=true ;;
            --interactive) INTERACTIVE=true ;;
            --skip-update) SKIP_UPDATE=true ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
        shift
    done

    if [ "$INTERACTIVE" = true ]; then
        echo "Select tools to install (y/n):"
        read -p "Install Docker? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_DOCKER=true
        read -p "Install AWS CLI? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_AWS=true
        read -p "Install Terraform? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_TERRAFORM=true
        read -p "Install kubectl? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_KUBECTL=true
        read -p "Install Node.js? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_NODE=true
        read -p "Install Ansible? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_ANSIBLE=true
        read -p "Install Docker Compose? (y/n) " yn; [[ $yn == [Yy]* ]] && INSTALL_DOCKER_COMPOSE=true
    fi
fi

# ========================
# Execute Commands
# ========================
case $COMMAND in
    install)
        install_tools
        ;;
    validate)
        validate_tools
        ;;
    cleanup)
        clean_environment
        ;;
    --help)
        show_help
        ;;
    --version)
        show_version
        ;;
    *)
        show_help
        ;;
esac
