# ===============================
# LOGGER
# ===============================

log() {
echo "$(date) : $1" >> "$LOG_FILE"
}

# ===============================
# SPINNER
# ===============================

spinner() {
pid=$!
spin='-\|/'
i=0
while kill -0 $pid 2>/dev/null; do
i=$(( (i+1) %4 ))
printf "\r${YELLOW}[%c] Working...${RESET}" "${spin:$i:1}"
sleep .1
done
printf "\r"
}

# ===============================
# ENVIRONMENT DETECTION
# ===============================

detect_os() {
OS=$(uname -s)

case "$OS" in
Linux*) PLATFORM="Linux" ;;
Darwin*) PLATFORM="MacOS" ;;
CYGWIN*|MINGW*|MSYS*) PLATFORM="Windows" ;;
*) PLATFORM="Unknown" ;;
esac

echo -e "${GREEN}[вң”] OS Detected:${RESET} $PLATFORM"
}

detect_architecture() {
ARCH=$(uname -m)

case "$ARCH" in
x86_64) ARCH_TYPE="amd64" ;;
aarch64|arm64) ARCH_TYPE="arm64" ;;
*) ARCH_TYPE="unknown" ;;
esac

echo -e "${GREEN}[вң”] Architecture:${RESET} $ARCH_TYPE"
}

detect_cloud() {

if curl -s --connect-timeout 1 http://169.254.169.254/latest/meta-data/ >/dev/null; then
    CLOUD="AWS"
elif curl -s --connect-timeout 1 http://metadata.google.internal >/dev/null; then
    CLOUD="GCP"
elif curl -s --connect-timeout 1 -H Metadata:true \
http://169.254.169.254/metadata/instance?api-version=2021-02-01 >/dev/null; then
    CLOUD="Azure"
else
    CLOUD="Local Machine"
fi

echo -e "${GREEN}[вң”] Cloud:${RESET} $CLOUD"
}

detect_container() {

if grep -qa docker /proc/1/cgroup 2>/dev/null; then
    ENVIRONMENT="Docker Container"
elif command -v systemd-detect-virt &>/dev/null && systemd-detect-virt -q; then
    ENVIRONMENT="Virtual Machine"
else
    ENVIRONMENT="Bare Metal"
fi

echo -e "${GREEN}[вң”] Runtime:${RESET} $ENVIRONMENT"
}

auto_detect() {
banner
echo -e "${CYAN}Running Intelligent Environment Detection...${RESET}"
echo ""
detect_os
detect_architecture
detect_cloud
detect_container
}

# ===============================
# INSTALL HELPERS
# ===============================

install_if_missing() {
CMD=$1
INSTALL_CMD=$2
NAME=$3

if command -v $CMD &>/dev/null; then
echo -e "${GREEN}[вң”] $NAME already installed${RESET}"
else
echo -e "${CYAN}Installing $NAME...${RESET}"
(eval "$INSTALL_CMD") & spinner
echo -e "${GREEN}[вң”] $NAME installed${RESET}"
fi
}

install_tools() {

banner
echo -e "${CYAN}Starting DevOps setup...${RESET}"

sudo dnf update -y & spinner

for arg in "$@"; do
case $arg in
docker)
install_if_missing docker "sudo dnf install docker -y && sudo systemctl enable --now docker" Docker
;;
aws)
install_if_missing aws "sudo dnf install awscli -y" "AWS CLI"
;;
terraform)
install_if_missing terraform "sudo dnf install terraform -y" Terraform
;;
kubectl)
install_if_missing kubectl "curl -LO https://dl.k8s.io/release/\$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl && chmod +x kubectl && sudo mv kubectl /usr/local/bin/" kubectl
;;
node)
install_if_missing node "sudo dnf install nodejs -y" Node.js
;;
ansible)
install_if_missing ansible "sudo dnf install ansible -y" Ansible
;;
docker-compose)
install_if_missing docker-compose "sudo dnf install docker-compose-plugin -y" Docker Compose
;;
esac
done

echo -e "${GREEN}Installation Completed!${RESET}"
}

# ===============================
# DOCTOR
# ===============================

doctor() {
banner
echo -e "${CYAN}System Diagnostics${RESET}"

for cmd in docker aws terraform kubectl node ansible docker-compose; do
if command -v $cmd &>/dev/null; then
echo -e "${GREEN}[вң”] $cmd installed${RESET}"
else
echo -e "${YELLOW}[вҡ ] $cmd missing${RESET}"
fi
done
}

# ===============================
# UPDATE
# ===============================

update_devsetupx() {
echo "Updating DevSetupX..."
curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetupx | sudo bash
}

# ===============================
# HELP
# ===============================

help_menu() {
banner
cat <<EOF
Usage:
  devsetupx <command>

Commands:
  detect        Intelligent environment detection
  install       Install DevOps tools
  doctor        Diagnose environment
  update        Update DevSetupX
  --help        Show help
  --version     Show version

Examples:
  devsetupx detect
  devsetupx install docker terraform
EOF
}

# ===============================
# MAIN
# ===============================

case "$1" in
detect)
auto_detect
;;
install)
shift
install_tools "$@"
;;
doctor)
doctor
;;
update)
update_devsetupx
;;
--help|"")
help_menu
;;
--version)
echo "DevSetupX v$VERSION"
;;
*)
echo "Unknown command"
help_menu
;;
esac
