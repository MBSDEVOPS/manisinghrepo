# ===================================
# DETECTION ENGINE (NEW FEATURES)
# ===================================

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
    else
        OS=$(uname -s)
    fi
    echo -e "${GREEN}OS:${RESET} $OS"
}

detect_architecture() {
    ARCH=$(uname -m)
    case $ARCH in
        x86_64) ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
    esac
    echo -e "${GREEN}Architecture:${RESET} $ARCH"
}

detect_cloud() {
    CLOUD="Local Machine"

    curl -s --connect-timeout 1 http://169.254.169.254/latest/meta-data/ &>/dev/null && CLOUD="AWS"
    curl -s --connect-timeout 1 -H Metadata:true "http://169.254.169.254/metadata/instance" &>/dev/null && CLOUD="Azure"

    echo -e "${GREEN}Cloud:${RESET} $CLOUD"
}

detect_container() {
    if grep -qa docker /proc/1/cgroup; then
        ENV="Docker Container"
    else
        ENV="VM / Bare Metal"
    fi
    echo -e "${GREEN}Environment:${RESET} $ENV"
}

doctor() {
    banner
    echo -e "${CYAN}System Diagnostics${RESET}"
    detect_os
    detect_architecture
    detect_cloud
    detect_container

    for cmd in docker aws terraform kubectl node ansible; do
        command -v $cmd &>/dev/null \
        && echo -e "${GREEN}[вң”] $cmd installed${RESET}" \
        || echo -e "${YELLOW}[вҡ ] $cmd missing${RESET}"
    done
}

# ===================================
# INSTALL ENGINE (OLD FEATURES KEPT)
# ===================================

install_if_missing() {
CMD=$1
INSTALL_CMD=$2
NAME=$3

if command -v $CMD &>/dev/null; then
    echo -e "${GREEN}[вң”] $NAME already installed${RESET}"
else
    echo -e "${CYAN}Installing $NAME...${RESET}"
    eval "$INSTALL_CMD"
fi
}

install_tools() {

sudo dnf update -y

for arg in "$@"; do
case $arg in
docker)
install_if_missing docker "sudo dnf install docker -y && sudo systemctl enable --now docker" Docker ;;
aws)
install_if_missing aws "sudo dnf install awscli -y" "AWS CLI" ;;
terraform)
install_if_missing terraform "sudo dnf install terraform -y" Terraform ;;
kubectl)
install_if_missing kubectl "sudo dnf install kubectl -y" kubectl ;;
node)
install_if_missing node "sudo dnf install nodejs -y" Node ;;
ansible)
install_if_missing ansible "sudo dnf install ansible -y" Ansible ;;
esac
done

echo -e "${GREEN}Installation Completed${RESET}"
}

