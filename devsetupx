set -euo pipefail

########################################
# COLORS
########################################
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[1;35m'
NC='\033[0m'

success(){ echo -e "${GREEN}✔ $1${NC}"; }
error(){ echo -e "${RED}✖ $1${NC}"; }
info(){ echo -e "${CYAN}➜ $1${NC}"; }
warn(){ echo -e "${YELLOW}⚠ $1${NC}"; }

########################################
# SAFETY CHECKS
########################################
command -v sudo >/dev/null || { echo "sudo required"; exit 1; }

########################################
# DETECTION ENGINE
########################################
detect_os(){ 
    case "$(uname -s)" in 
        Linux*) OS="Linux" ;; 
        Darwin*) OS="macOS" ;; 
        *) OS="Unknown" ;; 
    esac 
}
detect_arch(){ 
    case "$(uname -m)" in 
        x86_64) ARCH="amd64" ;; 
        aarch64|arm64) ARCH="arm64" ;; 
        *) ARCH="unknown" ;; 
    esac 
}
detect_pkg(){ 
    if command -v apt >/dev/null; then PKG="apt"
    elif command -v dnf >/dev/null; then PKG="dnf"
    elif command -v yum >/dev/null; then PKG="yum"
    elif command -v brew >/dev/null; then PKG="brew"
    else PKG="unknown"
    fi
}

########################################
# TOOL DETECTION
########################################
already_installed(){ command -v "$1" >/dev/null 2>&1; }
install_pkg(){ 
    PK=$1
    if already_installed "$PK"; then 
        success "$PK already installed (skipped)"; 
        return 
    fi
    info "Installing $PK..."
    case "$PKG" in 
        apt) sudo apt-get update -y && sudo apt-get install -y "$PK" ;; 
        dnf|yum) sudo $PKG install -y "$PK" ;; 
        brew) brew install "$PK" ;; 
        *) error "Unsupported package manager"; return ;; 
    esac
    success "$PK installed"
}

