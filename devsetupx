########################################
# CLOUD PROFILE
########################################
cloud_profile(){
  case "$CLOUD" in
    AWS) install_pkg awscli ;;
    Azure) install_pkg azure-cli ;;
    GCP) install_pkg google-cloud-cli ;;
    *) info "Local environment detected" ;;
  esac
}

########################################
# INSTALLERS
########################################
install_docker(){ install_pkg docker.io; sudo systemctl enable docker || true; sudo systemctl start docker || true; sudo usermod -aG docker "$USER"; }
install_docker_compose(){ install_pkg docker-compose; }
install_kubectl(){ install_pkg kubectl || true; }
install_terraform(){ install_pkg terraform || true; }
install_node(){ install_pkg nodejs; install_pkg npm; }
install_aws(){ install_pkg awscli; }
install_openshift(){ install_pkg origin-clients || true; }

install_ansible(){
  install_pkg python3
  install_pkg python3-pip
  install_pkg sshpass

  pip3 install --user --upgrade pip
  pip3 install --user ansible-core

  export PATH=$PATH:$HOME/.local/bin

  ansible --version >/dev/null && success "Ansible installed successfully" || { error "Ansible failed"; exit 1; }

  mkdir -p ~/ansible

cat <<EOF > ~/ansible/hosts
[local]
localhost ansible_connection=local
EOF

cat <<EOF > ~/ansible/ansible.cfg
[defaults]
inventory = ./hosts
host_key_checking = False
retry_files_enabled = False
EOF

  [ -f ~/.ssh/id_rsa ] || ssh-keygen -t rsa -N "" -f ~/.ssh/id_rsa

  success "Ansible fully configured"
}

########################################
# INTERACTIVE INSTALLATION
########################################
ask_install(){
  read -p "Do you want to install $1? (y/n): " choice
  case "$choice" in
    y|Y) $2 ;;
    n|N) info "Skipping $1" ;;
    *) warn "Invalid choice, skipping $1" ;;
  esac
}

install_all_interactive(){
  cloud_profile
  ask_install "Docker" install_docker
  ask_install "Docker Compose" install_docker_compose
  ask_install "kubectl" install_kubectl
  ask_install "Terraform" install_terraform
  ask_install "Node.js" install_node
  ask_install "AWS CLI" install_aws
  ask_install "Ansible (Enterprise)" install_ansible
  ask_install "OpenShift CLI" install_openshift
}

########################################
# AUTOMATION INSTALL
########################################
install_all(){
  cloud_profile
  install_docker
  install_docker_compose
  install_kubectl
  install_terraform
  install_node
  install_aws
  install_ansible
  install_openshift
}

########################################
# MENU (OPTIONAL)
########################################
menu(){
while true; do
echo ""
echo "1) Docker"
echo "2) Docker Compose"
echo "3) kubectl"
echo "4) Terraform"
echo "5) Node.js"
echo "6) AWS CLI"
echo "7) Ansible (Enterprise)"
echo "8) OpenShift CLI"
echo "9) Install ALL"
echo "0) Exit"

read -p "Choose option: " opt

case $opt in
1) install_docker ;;
2) install_docker_compose ;;
3) install_kubectl ;;
4) install_terraform ;;
5) install_node ;;
6) install_aws ;;
7) install_ansible ;;
8) install_openshift ;;
9) install_all ;;
0) exit 0 ;;
*) warn "Invalid option" ;;
esac
done
}

########################################
# ENTRY POINT
########################################
if [[ "${1:-}" == "--auto" ]]; then
  case "${2:-}" in
    docker) install_docker ;;
    compose) install_docker_compose ;;
    kubectl) install_kubectl ;;
    terraform) install_terraform ;;
    node) install_node ;;
    aws) install_aws ;;
    ansible) install_ansible ;;
    openshift) install_openshift ;;
    all) install_all ;;
    *) error "Unknown automation target" ;;
  esac
elif [[ "${1:-}" == "--interactive" ]]; then
  install_all_interactive
else
  menu
fi
