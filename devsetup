################ SPINNER ################
spinner() {
pid=$!
spin='-\|/'
i=0
while kill -0 $pid 2>/dev/null; do
i=$(( (i+1) %4 ))
printf "\r${YELLOW}[%c] Working...${RESET}" "${spin:$i:1}"
sleep .1
done
printf "\r"
}

################ LOG ################
log() {
mkdir -p "$LOG_DIR"
echo "$(date) : $1" >> "$LOG_FILE"
}

################ CONFIG ################
create_config() {
mkdir -p "$CONFIG_DIR"
touch "$CONFIG_FILE"
}

################ DEPENDENCIES ################
install_dependencies() {

command -v curl >/dev/null || sudo dnf install -y curl || sudo apt-get install -y curl
command -v unzip >/dev/null || sudo dnf install -y unzip || sudo apt-get install -y unzip
command -v python3 >/dev/null || sudo dnf install -y python3 || sudo apt-get install -y python3
command -v pip3 >/dev/null || sudo dnf install -y python3-pip || sudo apt-get install -y python3-pip

}

################ IDP INSTALL CHECK ################
install_if_missing() {
CMD=$1
INSTALL_CMD=$2

if command -v $CMD >/dev/null; then
echo -e "${GREEN}[‚úĒ] $CMD already installed${RESET}"
else
echo -e "${CYAN}Installing $CMD...${RESET}"
(eval "$INSTALL_CMD") & spinner
echo -e "${GREEN}[‚úĒ] $CMD installed${RESET}"
log "$CMD installed"
fi
}

################ TOOL INSTALL ################
install_tools() {

shift

if [[ "$#" -eq 0 || "$1" == "--interactive" ]]; then
echo "Install Docker? (y/n)"
read d
echo "Install Terraform? (y/n)"
read t
echo "Install AWS CLI? (y/n)"
read a
echo "Install kubectl? (y/n)"
read k
echo "Install Node.js? (y/n)"
read n
echo "Install Ansible? (y/n)"
read an
else
for arg in "$@"; do
case $arg in
docker) d="y" ;;
terraform) t="y" ;;
aws) a="y" ;;
kubectl) k="y" ;;
node) n="y" ;;
ansible) an="y" ;;
esac
done
fi

[[ "$d" == "y" ]] && install_if_missing docker "sudo dnf install -y docker || sudo apt install -y docker.io"
[[ "$t" == "y" ]] && install_if_missing terraform "sudo dnf install -y terraform"
[[ "$a" == "y" ]] && install_if_missing aws "sudo dnf install -y awscli"
[[ "$k" == "y" ]] && install_if_missing kubectl "sudo dnf install -y kubectl"
[[ "$n" == "y" ]] && install_if_missing node "sudo dnf module install nodejs -y || sudo apt install -y nodejs"
[[ "$an" == "y" ]] && install_if_missing ansible "pip3 install ansible"

mkdir -p ~/projects/dev ~/projects/test ~/projects/scripts
echo -e "${GREEN}[‚úĒ] Directories provisioned${RESET}"

}

################ VALIDATE ################
validate_tools() {
echo -e "${CYAN}Validating tools...${RESET}"
for tool in docker aws terraform kubectl node ansible; do
if command -v $tool >/dev/null; then
echo -e "${GREEN}$tool installed${RESET}"
else
echo -e "${YELLOW}$tool NOT installed${RESET}"
fi
done
}

################ CLEANUP ################
cleanup() {
rm -rf ~/projects
echo -e "${GREEN}Environment cleaned${RESET}"
}

################ DOCTOR ################
doctor() {
echo "System Diagnostics"
uname -a
df -h
free -m
}

################ AUTO UPDATE ################
update_devsetup() {
echo "Updating DevSetup..."
sudo curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetup -o /usr/local/bin/devsetup
sudo chmod +x /usr/local/bin/devsetup
echo -e "${GREEN}Updated successfully${RESET}"
}

################ HELP ################
help_menu() {
echo "Usage:"
echo " devsetup install [docker terraform aws kubectl node ansible]"
echo " devsetup install --interactive"
echo " devsetup validate"
echo " devsetup cleanup"
echo " devsetup doctor"
echo " devsetup update"
echo " devsetup --help"
echo " devsetup --version"
}

################ MAIN ################
create_config
install_dependencies
banner

case "$1" in
install)
install_tools "$@"
;;
validate)
validate_tools
;;
cleanup)
cleanup
;;
doctor)
doctor
;;
update)
update_devsetup
;;
--help|"")
help_menu
;;
--version)
echo "DevSetup CLI Tool v$VERSION"
;;
*)
echo "Unknown command"
help_menu
;;
esac
