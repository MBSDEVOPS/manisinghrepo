########################################
# DETECTION ENGINE
########################################
detect_os() {
OS=$(uname -s)
case "$OS" in
 Linux*) OS="Linux" ;;
 Darwin*) OS="macOS" ;;
 *) OS="Unknown" ;;
esac
}

detect_arch() {
ARCH=$(uname -m)
case "$ARCH" in
 x86_64) ARCH="amd64" ;;
 aarch64|arm64) ARCH="arm64" ;;
esac
}

detect_pkg_manager() {
if command -v apt >/dev/null; then PKG="apt"
elif command -v yum >/dev/null; then PKG="yum"
elif command -v dnf >/dev/null; then PKG="dnf"
elif command -v brew >/dev/null; then PKG="brew"
else PKG="unknown"
fi
}

detect_cloud() {
CLOUD="local"

curl -s --connect-timeout 1 \
http://169.254.169.254/latest/meta-data/ >/dev/null && CLOUD="AWS"

curl -s --connect-timeout 1 \
-H Metadata:true \
"http://169.254.169.254/metadata/instance?api-version=2021-02-01" \
>/dev/null && CLOUD="Azure"

curl -s --connect-timeout 1 \
-H "Metadata-Flavor: Google" \
http://metadata.google.internal >/dev/null && CLOUD="GCP"
}

detect_container() {
if grep -qa docker /proc/1/cgroup 2>/dev/null; then
ENVTYPE="Docker"
else
ENVTYPE="Host/VM"
fi
}

run_detect() {
detect_os
detect_arch
detect_pkg_manager
detect_cloud
detect_container

echo "OS: $OS"
echo "Architecture: $ARCH"
echo "Package Manager: $PKG"
echo "Cloud: $CLOUD"
echo "Environment: $ENVTYPE"
}

########################################
# INSTALL ENGINE (IDEMPOTENT)
########################################
install_tool() {
TOOL=$1
if command -v "$TOOL" >/dev/null; then
 ok "$TOOL already installed"
 return
fi

info "Installing $TOOL..."

case "$PKG" in
 apt) sudo apt update && sudo apt install -y "$TOOL" ;;
 yum|dnf) sudo $PKG install -y "$TOOL" ;;
 brew) brew install "$TOOL" ;;
 *) err "Unsupported package manager";;
esac
}

########################################
# AUTO CLOUD PROFILE SWITCH ‚≠ź
########################################
cloud_profile() {
case "$CLOUD" in
 AWS) ok "AWS detected ‚Üí preparing awscli profile"; install_tool awscli ;;
 Azure) ok "Azure detected ‚Üí preparing az cli"; install_tool azure-cli ;;
 GCP) ok "GCP detected ‚Üí preparing gcloud"; install_tool google-cloud-cli ;;
 *) info "Local environment detected";;
esac
}

########################################
# INTERACTIVE MODE
########################################
interactive() {
banner
run_detect
cloud_profile

echo ""
echo "Select tool:"
echo "1) git"
echo "2) docker"
echo "3) kubectl"
read -p "Choice: " c

case $c in
1) install_tool git ;;
2) install_tool docker ;;
3) install_tool kubectl ;;
*) warn "Invalid choice" ;;
esac
}

########################################
# DOCTOR
########################################
doctor() {
info "Running health checks..."

for cmd in git curl; do
 command -v $cmd >/dev/null \
   && ok "$cmd OK" \
   || warn "$cmd missing"
done
}

########################################
# PLUGIN SYSTEM
########################################
load_plugins() {
PLUGIN_DIR="$HOME/.devsetupx/plugins"
[ -d "$PLUGIN_DIR" ] || return

for p in "$PLUGIN_DIR"/*.sh; do
 [ -f "$p" ] && source "$p"
done
}

########################################
# SELF UPDATE
########################################
self_update() {
info "Checking updates..."
LATEST=$(curl -s $REPO_URL/VERSION_X)

if [ "$LATEST" != "$VERSION" ]; then
 info "Updating to $LATEST"
 sudo curl -fsSL $REPO_URL/devsetupx \
   -o /usr/local/bin/devsetupx
 sudo chmod +x /usr/local/bin/devsetupx
 ok "Updated!"
else
 ok "Already latest"
fi
}

########################################
# HELP
########################################
help_menu() {
banner
cat <<EOF
Usage: devsetupx <command>

Commands:
 detect        Show system info
 doctor        Health check
 install <pkg> Install package
 interactive   Guided install mode
 update        Self update
 clean         Clear logs
 --version     Show version
 --help        Help
EOF
}

########################################
# CLEAN
########################################
clean_logs() {
rm -f "$LOG_FILE"
ok "Logs cleaned"
}

########################################
# ROUTER (ENTERPRISE CLI)
########################################
load_plugins
detect_os
detect_arch
detect_pkg_manager
detect_cloud
detect_container

case "$1" in
 detect) run_detect ;;
 doctor) doctor ;;
 install) install_tool "$2" ;;
 interactive|-i) interactive ;;
 update) self_update ;;
 clean) clean_logs ;;
 --version) echo "DevSetupX v$VERSION" ;;
 --help|"") help_menu ;;
 *) err "Unknown command"; help_menu ;;
esac
