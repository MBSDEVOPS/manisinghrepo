# ---------------- DETECTIONS ----------------

detect_os(){
source /etc/os-release 2>/dev/null
OS=$ID
}

detect_architecture(){
ARCH=$(uname -m)
case $ARCH in
x86_64) ARCH="amd64" ;;
aarch64|arm64) ARCH="arm64" ;;
esac
}

detect_pkg_manager(){
if command -v apt &>/dev/null; then PKG="apt"
elif command -v dnf &>/dev/null; then PKG="dnf"
elif command -v yum &>/dev/null; then PKG="yum"
else PKG="unknown"
fi
}

detect_cloud(){
if curl -s --connect-timeout 1 http://169.254.169.254/latest/meta-data/ &>/dev/null; then
 CLOUD="AWS"
elif curl -s -H Metadata:true --connect-timeout 1 \
 http://169.254.169.254/metadata/instance &>/dev/null; then
 CLOUD="AZURE"
elif curl -s -H "Metadata-Flavor: Google" --connect-timeout 1 \
 http://169.254.169.254/computeMetadata/v1/ &>/dev/null; then
 CLOUD="GCP"
else
 CLOUD="LOCAL"
fi
}

detect_container(){
grep -qa docker /proc/1/cgroup && ENV="Docker" || ENV="VM/Host"
}

run_detection(){
detect_os
detect_architecture
detect_pkg_manager
detect_cloud
detect_container
}

# ---------------- ENTERPRISE FEATURE ----------------
# AUTO CLOUD PROFILE SWITCHING

auto_profile(){
run_detection

echo -e "${CYAN}Auto Profile Selection:${RESET}"

case $CLOUD in
AWS)
 echo -e "${GREEN}AWS environment detected${RESET}"
 DEFAULT_TOOLS="docker aws terraform"
 ;;
AZURE)
 echo -e "${GREEN}Azure environment detected${RESET}"
 DEFAULT_TOOLS="docker terraform"
 ;;
GCP)
 echo -e "${GREEN}GCP environment detected${RESET}"
 DEFAULT_TOOLS="docker terraform"
 ;;
LOCAL)
 echo -e "${YELLOW}Local environment detected${RESET}"
 DEFAULT_TOOLS="docker node"
 ;;
esac
}

# ---------------- INSTALL ENGINE ----------------

install_pkg(){
case $PKG in
apt) sudo apt update -y && sudo apt install -y "$1" ;;
dnf|yum) sudo $PKG install -y "$1" ;;
*) echo "Unsupported package manager" ;;
esac
}

install_tools(){
run_detection
auto_profile

echo -e "${CYAN}Installing profile tools: $DEFAULT_TOOLS${RESET}"

for tool in $DEFAULT_TOOLS; do
 if command -v $tool &>/dev/null; then
   echo -e "${GREEN}[вң”] $tool exists${RESET}"
 else
   echo -e "${CYAN}Installing $tool${RESET}"
   install_pkg $tool
 fi
done
}

