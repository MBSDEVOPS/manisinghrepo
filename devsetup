# =====================================
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
BLUE="\033[0;34m"
NC="\033[0m"

success(){ echo -e "${GREEN}[тЬФ] $1${NC}" | tee -a "$LOG_FILE"; }
warning(){ echo -e "${YELLOW}[тЪа] $1${NC}" | tee -a "$LOG_FILE"; }
error(){ echo -e "${RED}[тЬЦ] $1${NC}" | tee -a "$LOG_FILE"; }
info(){ echo -e "${BLUE}[тЮЬ] $1${NC}" | tee -a "$LOG_FILE"; }

