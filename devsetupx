#!/bin/bash

# ===============================
# DevSetupX Self Installer
# ===============================

INSTALL_PATH="/usr/local/bin/devsetupx"

if [[ "$0" == "bash" || "$0" == "sh" ]]; then
    echo "[DevSetupX] Installing globally..."

    TMP_FILE="/tmp/devsetupx"

    curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetupx -o "$TMP_FILE"

    sudo mv "$TMP_FILE" "$INSTALL_PATH"
    sudo chmod +x "$INSTALL_PATH"

    echo ""
    echo "вң… DevSetupX installed successfully!"
    echo "Run: devsetupx --help"
    echo ""
    exit 0
fi

# ===============================
# CONFIG
# ===============================

VERSION="1.0.1"
LOG_DIR="$HOME/.devsetupx/logs"
LOG_FILE="$LOG_DIR/devsetupx.log"
CONFIG_DIR="$HOME/.devsetupx"

mkdir -p "$LOG_DIR"
mkdir -p "$CONFIG_DIR"

