#!/bin/bash

# ===============================
# DevSetup Self Installer
# ===============================

INSTALL_PATH="/usr/local/bin/devsetup"

if [[ "$0" == "bash" || "$0" == "sh" ]]; then
    echo "[DevSetup] Installing globally..."

    TMP_FILE="/tmp/devsetup"

    curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetup -o "$TMP_FILE"

    sudo mv "$TMP_FILE" "$INSTALL_PATH"
    sudo chmod +x "$INSTALL_PATH"

    echo ""
    echo "✅ DevSetup installed successfully!"
    echo "Run: devsetup --help"
    echo ""
    exit 0
fi

# ===============================
# CONFIG
# ===============================

VERSION="1.0.0"
LOG_DIR="$HOME/.devsetup/logs"
LOG_FILE="$LOG_DIR/devsetup.log"
CONFIG_DIR="$HOME/.devsetup"

mkdir -p "$LOG_DIR"
mkdir -p "$CONFIG_DIR"

# ===============================
# COLORS
# ===============================

GREEN="\e[32m"
YELLOW="\e[33m"
RED="\e[31m"
BLUE="\e[34m"
CYAN="\e[36m"
RESET="\e[0m"

# ===============================
# BANNER (YOUR ORIGINAL STYLE)
# ===============================

banner() {
echo -e "$BLUE"
cat << "EOF"

██████╗ ███████╗██╗   ██╗███████╗███████╗████████╗██╗   ██╗██████╗
██╔══██╗██╔════╝██║   ██║██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗
██║  ██║█████╗  ██║   ██║███████╗█████╗     ██║   ██║   ██║██████╔╝
██║  ██║██╔══╝  ╚██╗ ██╔╝╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝
██████╔╝███████╗ ╚████╔╝ ███████║███████╗   ██║   ╚██████╔╝██║
╚═════╝ ╚══════╝  ╚═══╝  ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝

EOF
echo -e "$CYAN DevSetup CLI Tool v$VERSION $RESET"
echo -e "$YELLOW DevOps Environment Automation $RESET"
echo ""
}

# ===============================
# SPINNER
# ===============================

spinner() {
pid=$!
spin='-\|/'
i=0
while kill -0 $pid 2>/dev/null; do
i=$(( (i+1) %4 ))
printf "\r${YELLOW}[%c] Working...${RESET}" "${spin:$i:1}"
sleep .1
done
printf "\r"
}

log() {
echo "$(date) : $1" >> "$LOG_FILE"
}

# ===============================
# DIRECTORY PROVISIONING
# ===============================

setup_dirs() {
mkdir -p ~/projects/dev ~/projects/test ~/projects/scripts
log "Directories created"
}

# ===============================
# INSTALL FUNCTIONS (IDEMPOTENT)
# ===============================

install_if_missing() {
CMD=$1
INSTALL_CMD=$2
NAME=$3

if command -v $CMD &>/dev/null; then
echo -e "${GREEN}[✔] $NAME already installed${RESET}"
else
echo -e "${CYAN}Installing $NAME...${RESET}"
(eval "$INSTALL_CMD") & spinner
echo -e "${GREEN}[✔] $NAME installed${RESET}"
fi
}

install_tools() {

echo -e "${CYAN}Starting DevOps environment setup...${RESET}"
setup_dirs

sudo dnf update -y & spinner

for arg in "$@"; do
case $arg in
docker)
install_if_missing docker "sudo dnf install docker -y && sudo systemctl enable --now docker" Docker
;;
aws)
install_if_missing aws "sudo dnf install awscli -y" "AWS CLI"
;;
terraform)
install_if_missing terraform "sudo dnf install -y yum-utils && sudo yum-config-manager --add-repo https://rpm.releases.hashicorp.com/AmazonLinux/hashicorp.repo && sudo dnf install terraform -y" Terraform
;;
kubectl)
install_if_missing kubectl "curl -LO https://dl.k8s.io/release/\$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl && chmod +x kubectl && sudo mv kubectl /usr/local/bin/" kubectl
;;
node)
install_if_missing node "sudo dnf install nodejs -y" Node.js
;;
ansible)
install_if_missing ansible "sudo dnf install ansible -y" Ansible
;;
docker-compose)
install_if_missing docker-compose "sudo dnf install docker-compose-plugin -y" Docker-Compose
;;
esac
done

echo -e "${GREEN}Installation Completed!${RESET}"
}

# ===============================
# INTERACTIVE MODE
# ===============================

interactive_mode() {
    banner
    echo -e "${CYAN}Welcome to Interactive DevSetup Mode!${RESET}"
    echo "Select the tools you want to install (y/n):"

    declare -A tools
    tools=( ["docker"]="Docker" ["aws"]="AWS CLI" ["terraform"]="Terraform" ["kubectl"]="kubectl" ["node"]="Node.js" ["ansible"]="Ansible" ["docker-compose"]="Docker-Compose" )

    selected_tools=()
    for key in "${!tools[@]}"; do
        read -rp "${tools[$key]}? [y/n]: " choice
        case "$choice" in
            y|Y) selected_tools+=("$key") ;;
            n|N) ;;
            *) echo "Skipping ${tools[$key]}" ;;
        esac
    done

    if [ ${#selected_tools[@]} -eq 0 ]; then
        echo -e "${YELLOW}No tools selected. Exiting interactive mode.${RESET}"
        exit 0
    fi

    echo -e "${CYAN}Installing selected tools...${RESET}"
    install_tools "${selected_tools[@]}"
}

# ===============================
# DOCTOR COMMAND
# ===============================

doctor() {
echo -e "${CYAN}System Diagnostics${RESET}"

for cmd in docker aws terraform kubectl node ansible docker-compose; do
if command -v $cmd &>/dev/null; then
echo -e "${GREEN}[✔] $cmd installed${RESET}"
else
echo -e "${YELLOW}[⚠] $cmd missing${RESET}"
fi
done
}

# ===============================
# CLEANUP
# ===============================

cleanup() {
rm -rf ~/projects
echo -e "${RED}Environment cleaned${RESET}"
}

# ===============================
# AUTO UPDATE
# ===============================

update_devsetup() {
echo "Updating DevSetup..."
curl -fsSL https://raw.githubusercontent.com/MBSDEVOPS/manisinghrepo/main/devsetup | sudo bash
}

# ===============================
# HELP
# ===============================

help_menu() {
banner
cat <<EOF
Usage:
  devsetup <command> [options]

Commands:
  install <tools>     Install tools
  --interactive, -i   Run interactive mode
  doctor              Diagnose environment
  cleanup             Remove created directories
  update              Update DevSetup
  --help              Show help
  --version           Show version

Examples:
  devsetup install docker terraform
  devsetup install docker aws kubectl
EOF
}

# ===============================
# MAIN
# ===============================

case "$1" in
install)
shift
banner
install_tools "$@"
;;
doctor)
banner
doctor
;;
cleanup)
banner
cleanup
;;
update)
update_devsetup
;;
--interactive|-i)
interactive_mode
;;
--help|"")
help_menu
;;
--version)
echo "DevSetup CLI Tool v$VERSION"
;;
*)
echo "Unknown command"
help_menu
;;
esac
